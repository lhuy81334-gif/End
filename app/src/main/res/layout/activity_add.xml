<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <TextView
        android:id="@+id/textviewSanPham"
        android:layout_width="match_parent"
        android:layout_height="55dp"

        android:gravity="center"
        android:text="THÊM PHỤ KIỆN"

        android:textSize="22sp"
        android:textStyle="bold" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="22dp">

        <ImageView
            android:id="@+id/imageview_no_imge"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"

            android:padding="20dp"
            android:src="@drawable/no_image" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/imagebutton_camera"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:text="Camera" />

            <Button
                android:id="@+id/imagebutton_folder"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Thư viện" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Mã phụ kiện"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edittextMaPK"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập mã phụ kiện" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Tên phụ kiện"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edittextTenSP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập tên phụ kiện" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Mô tả"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edittextMota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập mô tả"
            android:inputType="textMultiLine"
            android:minLines="2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonHuy"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="CANCEL" />

            <Button
                android:id="@+id/buttonAdd"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"

                android:text="ADD"
                />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>